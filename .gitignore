.vercel
.env*
!.env.example
node_modules/

# Relatorios .xlsx vivem no Drive e sao baixados no build (pull-relatorios.mjs).
# eventos-meta.json e manifest.json NAO sao ignorados (config/gerados).
assets/docs/relatorios/**/*.xlsx
assets/docs/relatorios/**/*.xls

# Relatorios de exemplo/modelo passados manualmente (referencia local).
# Grandes (PDF ~27MB) e com dados de participantes -> nao versionar nem publicar.
/Relatorio Satisfacao - *.pdf
/Relatorio Satisfacao - *.docx

# Backups locais (one-off) - podem conter dados de participantes; nao versionar.
backups/
