{
  "name": "dashboard",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/pull-relatorios.mjs && node scripts/normalize-planilhas.mjs && node scripts/build-data.mjs",
    "build:data": "node scripts/build-data.mjs",
    "build:normalize": "node scripts/normalize-planilhas.mjs",
    "build:pull": "node scripts/pull-relatorios.mjs",
    "migrate": "node --env-file=.env.local scripts/migrate.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint scripts lib api tests",
    "format": "prettier --write lib tests",
    "format:check": "prettier --check lib tests",
    "check": "npm run lint && npm run test"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  }
}
