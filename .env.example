# Exemplo de variáveis de ambiente. Copie para .env / .env.local e preencha.
# NÃO comite segredos: .env* está no .gitignore.

# --- Login social (Google Identity Services) ---
# O CLIENT_ID é público (vai também no front, em index.html).
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# O secret NÃO é usado pelo fluxo de ID token, mas fica reservado caso se migre
# para o fluxo de authorization code. Mantenha fora do controle de versão.
GOOGLE_CLIENT_SECRET=

# --- Banco de dados (allowlist de usuários: tabela app_users) ---
# Postgres institucional. Rode as migrations com: npm run migrate
# Ex.: postgresql://USUARIO:SENHA@HOST:5432/egov?sslmode=require
DATABASE_URL=
# PGSSL=disable   # use só em DB local sem TLS

# --- Login legado por e-mail/senha (fallback quando não há DATABASE_URL) ---
# Formato: "email|senha|Nome Completo"
AUTH_USER_EXEMPLO=fulano@pedroleopoldo.mg.gov.br|trocar-senha|Fulano de Tal

# --- Integrações Apps Script / Drive (já existentes) ---
RELATORIOS_WEBAPP_URL=
RELATORIOS_TOKEN=
INSCRICOES_WEBAPP_URL=
INSCRICOES_TOKEN=
LEMBRETES_WEBAPP_URL=
LEMBRETES_TOKEN=
PALESTRANTES_WEBAPP_URL=
PALESTRANTES_TOKEN=
